# Set to your server's IP for access from other devices (e.g., http://192.168.1.100:4000)
REACT_APP_BACKEND_URL=http://localhost:4000

# --- Backend-only settings (used by docker-compose, NOT exposed to the browser) ---
DB_PASSWORD=change-me
JWT_SECRET=your-secure-random-string-at-least-64-characters-long
CORS_ORIGIN=http://localhost:3000
# Set to your n8n instance URL, reachable from the backend container
N8N_BASE_URL=http://host.docker.internal:5678
N8N_API_HEADER=X-N8N-API-KEY
N8N_API_KEY=your_api_key_here
