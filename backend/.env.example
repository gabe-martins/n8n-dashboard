PORT=4000
DB_HOST=localhost
DB_PORT=5432
DB_NAME=n8n_dashboard
DB_USER=postgres
DB_PASSWORD=postgres
JWT_SECRET=your-secure-random-string-at-least-64-characters-long-replace-this
JWT_EXPIRES_IN=8h
# Use comma-separated values for multiple origins, or * for all
CORS_ORIGIN=*

# n8n connection (server-side only — never expose this key to the frontend)
N8N_BASE_URL=http://localhost:5678
N8N_API_HEADER=X-N8N-API-KEY
N8N_API_KEY=your_n8n_api_key_here
